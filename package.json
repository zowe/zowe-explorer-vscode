{
  "name": "zowe-explorer",
  "description": "Monorepo for the Zowe Explorer project.",
  "publisher": "Zowe",
  "author": "Zowe",
  "license": "EPL-2.0",
  "repository": {
    "url": "https://github.com/zowe/zowe-explorer-vscode"
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/zowe-explorer/src/webviews"
  ],
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "@vscode/l10n": "^0.0.18",
    "disposablestack": "^1.1.7"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.73.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-electron": "^1.6.2",
    "@vscode/vsce": "3.9.1",
    "ansi-colors": "^4.1.3",
    "concurrently": "^6.5.1",
    "esbuild-loader": "^4.4.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-deprecation": "^2.0.0",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-zowe-explorer": "workspace:./packages/eslint-plugin-zowe-explorer",
    "fancy-log": "^2.0.0",
    "fast-glob": "^3.3.3",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "husky": "^6.0.0",
    "jest-mock-vscode": "^3.0.5",
    "madge": "^7.0.0",
    "mocha": "^10.8.2",
    "mocha-junit-reporter": "^2.2.1",
    "mocha-multi-reporters": "^1.5.1",
    "node-loader": "^2.1.0",
    "prettier": "^2.8.8",
    "rimraf": "^3.0.2",
    "terser-webpack-plugin": "^5.3.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6",
    "webpack": "^5.105.2",
    "webpack-cli": "^5.1.4"
  },
  "scripts": {
    "clean": "pnpm -r clean",
    "fresh-clone": "pnpm -r --parallel fresh-clone && (rimraf node_modules || true)",
    "prepare": "husky install && node scripts/build-wdio-service.js",
    "lint": "pnpm -r lint",
    "madge": "pnpm -r madge",
    "pretty": "prettier --write .",
    "build": "pnpm -r --sequential --color --reporter=append-only build",
    "build:parallel": "pnpm -r build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:packages": "pnpm -r --sequential --color --reporter=append-only test",
    "test:parallel": "pnpm -r --parallel --color test",
    "package": "pnpm -r --sequential package",
    "preinstall": "npx only-allow pnpm",
    "update-sdks": "pnpm -r update \"@zowe/*@zowe-v3-lts\" \"!@zowe/zowe-explorer-api\" \"!@zowe/zos-ftp-for-zowe-cli\""
  }
}
