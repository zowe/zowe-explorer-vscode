{
  "name": "@zowe/zowex-for-zowe-explorer",
  "displayName": "Zowe Remote SSH",
  "description": "Zowe Remote SSH VS Code APIs for Zowe Explorer",
  "version": "0.4.0",
  "publisher": "Zowe",
  "repository": "https://github.com/zowe/zowe-explorer-vscode/tree/main/packages/zowex-for-zowe-explorer",
  "license": "EPL-2.0",
  "private": true,
  "main": "lib/index.js",
  "exports": {
    ".": {
      "@zowe:bundler": "./src/index.ts",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc -p ./ && pnpm madge",
    "clean": "rimraf bin lib coverage",
    "compile": "rspack --mode development",
    "license": "node ../../scripts/updateLicenses.mjs",
    "newlint": "concurrently -n \"_eslint_,prettier\" \"pnpm lint:all\" \"pnpm lint:pretty\"",
    "newlint:html": "(mkdir -p \"results\" || true) && eslint . --format html > results/eslint.html",
    "lint": "concurrently -n \"_eslint_,prettier\" \"pnpm lint:src\" \"pnpm lint:html\" \"pnpm lint:pretty\"",
    "lint:all": "pnpm run \"/^lint:[hst].*/\"",
    "lint:html": "(mkdir -p \"results\" || true) && eslint ./src --format html > results/eslint.html",
    "lint:pretty": "prettier --write . && prettier --check .",
    "lint:src": "eslint --format stylish src/**/*.ts",
    "lint:test": "eslint --format stylish tests/**/*.ts",
    "madge": "madge -c --no-color --no-spinner --exclude __mocks__ --extensions js,ts src/",
    "package": "vsce package --out ../../dist",
    "oldtest": "vitest run --coverage",
    "oldtest:ui": "vitest --ui --coverage",
    "oldtest:watch": "vitest --watch",
    "test": "echo 'Not Implemented'",
    "vscode:prepublish": "rspack --mode production",
    "watch": "rspack --mode development --watch"
  },
  "dependencies": {
    "@zowe/core-for-zowe-sdk": "^8.11.0",
    "@zowe/zowe-explorer-api": "workspace:* ",
    "ssh2": "^1.16.0",
    "@zowe/zowex-for-zowe-sdk": "^0.5.0"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.4",
    "@zowe/zos-files-for-zowe-sdk": "^8.30.1",
    "@zowe/zos-jobs-for-zowe-sdk": "^8.30.1",
    "@zowe/zos-uss-for-zowe-sdk": "^8.30.1"
  },
  "madge": {
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      }
    }
  }
}
