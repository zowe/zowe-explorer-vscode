{
  "name": "@zowe/zowe-native-api",
  "displayName": "Zowe Remote SSH",
  "description": "Zowe Remote SSH VS Code APIs for Zowe Explorer",
  "version": "0.4.0",
  "publisher": "Zowe",
  "repository": "https://github.com/zowe/zowe-explorer-vscode/tree/main/packages/zowe-native-api",
  "license": "EPL-2.0",
  "private": true,
  "main": "lib/index.js",
  "exports": {
    ".": {
      "@zowe:bundler": "./src/index.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p . --noEmit && pnpm madge",
    "clean": "rimraf bin out coverage",
    "compile": "rspack --mode development",
    "license": "node ../../scripts/updateLicenses.mjs",
    "lint": "npx @biomejs/biome check --write src benchmarks tests",
    "madge": "madge -c --no-color --no-spinner --exclude __mocks__ --extensions js,ts src/",
    "package": "vsce package --out ../../dist",
    "oldtest": "vitest run --coverage",
    "oldtest:ui": "vitest --ui --coverage",
    "oldtest:watch": "vitest --watch",
    "test": "echo 'Not Implemented'",
    "vscode:prepublish": "rspack --mode production",
    "watch": "rspack --mode development --watch"
  },
  "dependencies": {
    "@zowe/core-for-zowe-sdk": "^8.11.0",
    "@zowe/zowe-explorer-api": "workspace:* ",
    "ssh2": "^1.16.0",
    "@zowe/zowex-for-zowe-sdk": "file:../../../zowe-native-proto/packages/sdk"
  },
  "devDependencies": {
    "@types/ssh2": "^1.15.4",
    "@zowe/zos-files-for-zowe-sdk": "^8.30.1",
    "@zowe/zos-jobs-for-zowe-sdk": "^8.30.1",
    "@zowe/zos-uss-for-zowe-sdk": "^8.30.1"
  },
  "madge": {
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      }
    }
  }
}
