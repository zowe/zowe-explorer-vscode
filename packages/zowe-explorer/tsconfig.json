{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "outDir": "out",
    "jsx": "react",
    "lib": ["es6", "dom"],
    "skipLibCheck": true,
    "sourceMap": true,
    "esModuleInterop": true,
    /* Strict Type-Checking Option */
    "strict": false /* enable all strict type-checking options */,
    /* Additional Checks */
    "noUnusedLocals": true /* Report errors on unused locals. */,
    // "noImplicitReturns": true, /* Report error when not all code paths in function return a value. */
    // "noFallthroughCasesInSwitch": true, /* Report errors for fallthrough cases in switch statement. */
    // "noUnusedParameters": true,  /* Report errors on unused parameters. */
    "experimentalDecorators": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "composite": true,
    "paths": {
      "@zowe/zowe-explorer-api": ["../zowe-explorer-api"],
      "zowex-for-zowe-explorer": ["../zowex-for-zowe-explorer"]
    },
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    "src/webviews/src/certificate-wizard/**",
    "src/webviews/src/edit-attributes/**",
    "src/webviews/src/edit-history/**",
    "src/webviews/src/release-notes/**",
    "src/webviews/src/table-view/**",
    "src/webviews/src/troubleshoot-error/**",
    "src/webviews/src/zos-console/**",
    "src/webviews/src/config-editor/components/**",
    "src/webviews/src/config-editor/context/**",
    "src/webviews/src/config-editor/handlers/**",
    "src/webviews/src/config-editor/hooks/**",
    "src/webviews/src/MessageHandler.ts",
    "src/webviews/src/Messenger.ts",
    "src/webviews/src/PersistentVSCodeAPI.ts",
    "src/webviews/src/utils.ts",
    "src/webviews/src/config-editor/utils/index.ts",
    "src/webviews/src/config-editor/utils/propertyUtils.ts",
    "src/webviews/src/config-editor/utils/sortingUtils.ts",
    "src/webviews/src/config-editor/utils/schemaUtils.ts",
    "src/webviews/src/config-editor/utils/extensionRequests.ts",
    "src/webviews/src/config-editor/utils/generalUtils.ts",
    "src/webviews/src/config-editor/utils/renameUtils.ts",
    "src/webviews/src/config-editor/utils/profileUtils.ts",
    "src/webviews/src/config-editor/utils/profileRenames.ts",
    "src/webviews/src/config-editor/utils/profileTypeResolution.ts",
    "src/webviews/src/config-editor/utils/profileSecure.ts",
    "src/webviews/src/config-editor/utils/profileMergedProperties.ts",
    "src/webviews/src/config-editor/utils/profileKeyListing.ts",
    "src/webviews/src/config-editor/utils/configUtils.ts",
    "src/webviews/src/config-editor/utils/profileHelpers.ts",
    "src/webviews/src/config-editor/App.tsx",
    "src/webviews/src/config-editor/index.tsx",
    "src/webviews/vite.config.ts",
    "src/webviews/public/**",
    "src/webviews/dist/**",
    ".vscode-test"
  ],
  "include": [
    "src/**/*.ts",
    // Needed in production for vscode-nls localization to work:
    "./node_modules/vscode/vscode.d.ts",
    "./node_modules/vscode/lib/*",
    "package.json",
    "log4jsconfig.json"
  ],
  "references": [{ "path": "../zowe-explorer-api" }, { "path": "../zowex-for-zowe-explorer" }]
}
